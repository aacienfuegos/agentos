# === REQUIRED ===

# Anthropic API key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# GitHub personal access token — needs: repo, read:org, write:discussion
GITHUB_TOKEN=ghp_...

# Secret key for JWT signing — generate with: openssl rand -hex 32
SECRET_KEY=

# Admin password for the web panel
ADMIN_PASSWORD=

# === NOTIFICATIONS (optional) ===

# ntfy topic URL — e.g. https://ntfy.sh/my-secret-topic
# Leave empty to disable notifications
NTFY_URL=

# === BUDGET ALERTS (optional) ===

# Monthly budget in USD — triggers alert when exceeded (default: 50)
MONTHLY_BUDGET_USD=50

# === GITHUB WEBHOOKS (optional) ===

# Secret for GitHub webhook HMAC verification
# Generate with: openssl rand -hex 20
GITHUB_WEBHOOK_SECRET=

# === PRODUCTION ONLY ===

# Tailscale IP of the machine (for Caddy binding)
# Find with: tailscale ip -4
TAILSCALE_IP=100.x.x.x

# Backend URL (used by frontend in production)
BACKEND_URL=http://backend:8000
